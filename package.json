{
  "name": "vault-mode",
  "displayName": "Vault Mode",
  "description": "Wikilinks, backlinks, daily notes, a styled Markdown preview, and optional semantic search for markdown vaults. For VS Code, Cursor, and compatible editors.",
  "version": "0.2.0",
  "icon": "icon.png",
  "license": "MIT",
  "publisher": "yoonholee",
  "repository": {
    "type": "git",
    "url": "https://github.com/yoonholee/vault-mode.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Notebooks", "Other"],
  "keywords": [
    "wikilinks",
    "backlinks",
    "second brain",
    "zettelkasten",
    "knowledge base",
    "PKM",
    "notes",
    "daily notes",
    "bidirectional links",
    "markdown"
  ],
  "activationEvents": [
    "onLanguage:markdown",
    "workspaceContains:**/*.md"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      { "command": "vaultMode.semanticSearch", "title": "Vault: Semantic Search", "category": "Vault Mode" },
      { "command": "vaultMode.insertWikilink", "title": "Vault: Insert Wikilink", "category": "Vault Mode" },
      { "command": "vaultMode.relatedNotes", "title": "Vault: Show Related Notes", "category": "Vault Mode" },
      { "command": "vaultMode.openDailyNote", "title": "Vault: Open Today's Daily Note", "category": "Vault Mode" },
      { "command": "vaultMode.openRandomNote", "title": "Vault: Open Random Note", "category": "Vault Mode" },
      { "command": "vaultMode.regenerateCopilotInstructions", "title": "Vault: Regenerate Copilot Instructions", "category": "Vault Mode" },
      { "command": "vaultMode.preloadNeighbors", "title": "Vault: Preload Wikilink Neighbors", "category": "Vault Mode" },
      { "command": "vaultMode.rebuildIndex", "title": "Vault: Rebuild Workspace Index", "category": "Vault Mode" },
      { "command": "vaultMode.previewToSide", "title": "Vault: Open Markdown Preview to Side", "category": "Vault Mode", "icon": "$(layout-sidebar-right)" }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "vaultMode.previewToSide",
          "group": "navigation",
          "when": "resourceLangId == markdown || resourceLangId == prompt || resourceLangId == instructions || resourceLangId == chatagent || resourceLangId == skill"
        }
      ]
    },
    "configuration": {
      "title": "Vault Mode",
      "properties": {
        "vaultMode.vsPath": {
          "type": "string",
          "default": "vs",
          "description": "Path to the `vs` semantic-search CLI. Resolved against $PATH."
        },
        "vaultMode.vsTimeoutMs": {
          "type": "number",
          "default": 5000,
          "description": "Hard timeout for any `vs` invocation, in milliseconds."
        },
        "vaultMode.dailyNotesFolder": {
          "type": "string",
          "default": "Daily",
          "description": "Folder under the vault root where daily notes are created."
        },
        "vaultMode.dailyNoteTemplate": {
          "type": "string",
          "default": "# {date}\n\n",
          "description": "Template for new daily notes. Placeholders: {date}, {iso}, {weekday}."
        },
        "vaultMode.copilotBooster.enabled": {
          "type": "boolean",
          "default": false,
          "description": "EXPERIMENTAL: silently load wikilink neighbors of the active file into workspace.textDocuments so Copilot has them as context. Off by default; unclear whether Copilot's inline-completion heuristic actually reads silent-loaded documents. Use workspace.openTextDocument under the hood (no UI changes)."
        },
        "vaultMode.copilotBooster.maxNeighbors": {
          "type": "number",
          "default": 5,
          "description": "Maximum number of neighbor files to open as preview tabs per active file."
        },
        "vaultMode.copilotBooster.depth": {
          "type": "number",
          "default": 1,
          "description": "Traversal depth for neighbor preloading. 1 = direct wikilinks only."
        },
        "vaultMode.hover.augmentWithVs": {
          "type": "boolean",
          "default": true,
          "description": "Append top-3 vs semantic neighbors to wikilink hover popups."
        },
        "vaultMode.ignorePatterns": {
          "type": "array",
          "items": { "type": "string" },
          "default": [
            ".cache/**",
            ".obsidian/**",
            "Archive/**",
            "assets/**",
            "node_modules/**",
            "pdf-exports/**",
            "pdfs/**"
          ],
          "description": "Glob patterns excluded from the workspace index. Also reads .gitignore and .ignore at vault root."
        },
        "vaultMode.perfLog": {
          "type": "boolean",
          "default": true,
          "description": "Log timings for hot paths to the Vault Mode output channel."
        }
      }
    },
    "markdown.previewStyles": ["./styles/tokens.css", "./styles/preview.css"],
    "grammars": [
      {
        "scopeName": "markdown.wikilink.injection",
        "path": "./syntaxes/wikilink-injection.tmLanguage.json",
        "injectTo": ["text.html.markdown"]
      }
    ],
    "markdown.markdownItPlugins": true
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --target=node18",
    "build:watch": "npm run build -- --watch",
    "vscode:prepublish": "npm run build -- --minify",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:integration": "node ./out/test/runTest.js",
    "lint": "eslint src --ext ts && prettier --check src test",
    "lint:fix": "eslint src --ext ts --fix && prettier --write src test",
    "typecheck": "tsc --noEmit",
    "bench": "node ./scripts/bench-all.mjs"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/test-electron": "^2.4.0",
    "esbuild": "^0.23.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "markdown-it": "^14.1.0"
  }
}
